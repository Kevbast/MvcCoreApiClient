@section Scripts {

    <script>
        $(document).ready(function(){
            $("#btnhospitales").click(function(){
                let url="https://apicorehospitaleskbs.azurewebsites.net/";
                let request="/api/Hospitales"
                $.ajax({
                    url:url+request,
                    method:"GET",
                    success:function(data){
                        console.log("HOSPITAL FUNCIONAL")
                        var html="";
                        $.each(data,function(index,hospital){
                            html +="<tr>";
                            html +="<td>"+hospital.idHospital+"</td>";
                            html +="<td>"+hospital.nombre+"</td>";
                            html +="<td>"+hospital.direccion+"</td>";
                            html +="<td>"+hospital.telefono+"</td>";
                            html +="<td>"+hospital.camas+"</td>";
                            html +="</tr>";
                        })
                        //Añadimos el html a la tabla
                        $("#tablahospital tbody").html(html);
                    }
                })
            })
        })
    </script>
}

<div class="text-center">
    <h1 class="display-4" style="color:darkred">Api HOSPITALES Client</h1>

    <button id="btnhospitales" class="btn btn-warning"> Load HOSPITALES</button>
    <table class="table table-dark" id="tablahospital">
        <thead>
            <tr>
                <th>HOSPITAL_COD</th>
                <th>Nombre</th>
                <th>Direccion</th>
                <th>Telefono</th>
                <th>Numero de camas</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>
